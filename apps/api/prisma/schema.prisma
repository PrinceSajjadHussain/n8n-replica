generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String       @id @default(uuid())
  email        String       @unique
  passwordHash String
  createdAt    DateTime     @default(now())
  workflows    Workflow[]
  credentials  Credential[]
  folders      CredentialFolder[]
  sharedWithMe CredentialShare[]
  sharedWorkflowsWithMe WorkflowShare[]

  ownedWorkspaces   Workspace[]
  workspaceMembers  WorkspaceMember[]
  workflowComments  WorkflowComment[]
  activityLogs      ActivityLog[]

  @@index([email])
}

model Workflow {
  id         String   @id @default(uuid())
  userId     String
  name       String
  nodesJson  Json
  edgesJson  Json
  isActive   Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  publishedNodesJson Json?
  publishedEdgesJson Json?
  publishedVersion   Int      @default(0)
  draftVersion       Int      @default(0)

  workspaceId String?
  folderId    String?

  /// If set, this workflow auto-runs whenever THIS workflow's execution
  /// fails, receiving { failedWorkflowId, executionId, errorMessage, nodeId }
  /// as its trigger payload (n8n-style "Error Workflow").
  errorWorkflowId String?

  /// Last JSON body used to manually run this workflow, so the "test
  /// workflow" panel keeps its payload across editor sessions.
  lastManualTestPayload Json?

  /// Small persisted JSON blob for lightweight state between runs (e.g.
  /// "last processed id"), read/written via $getWorkflowStaticData() /
  /// $setWorkflowStaticData() in the Code node and {{$staticData.KEY}} in
  /// any node's params.
  staticData Json @default("{}")

  /// Max number of this workflow's executions allowed to run concurrently.
  /// null/unset = unlimited (subject only to the global WORKER_CONCURRENCY
  /// cap). Enforced in the worker via a Redis-backed slot count — see
  /// apps/worker/src/engine/concurrency.ts. Set from the canvas toolbar's
  /// "Settings" panel or PUT /workflows/:id.
  maxConcurrency Int?

  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  executions Execution[]
  versions   WorkflowVersion[]
  workspace  Workspace?       @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  folder     WorkflowFolder?  @relation(fields: [folderId], references: [id], onDelete: SetNull)
  comments   WorkflowComment[]
  activityLogs ActivityLog[]
  alertConfigs AlertConfig[]
  errorWorkflow    Workflow?  @relation("ErrorWorkflow", fields: [errorWorkflowId], references: [id], onDelete: SetNull)
  workflowsUsingMeAsErrorHandler Workflow[] @relation("ErrorWorkflow")
  tags       WorkflowTag[]
  shares     WorkflowShare[]
  testCases  WorkflowTestCase[]

  @@index([userId])
  @@index([workspaceId])
  @@index([folderId])
  @@index([errorWorkflowId])
}

/// Instance- or workspace-scoped key/value store, referenced in node
/// expressions as {{$vars.KEY}}. A null workspaceId is a global variable
/// visible to every workflow; a non-null workspaceId scopes it to that
/// workspace only.
model Variable {
  id          String    @id @default(uuid())
  workspaceId String?
  key         String
  value       String
  createdBy   String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
}

/// A named label, scoped to a workspace (or global if workspaceId is null),
/// attached to workflows many-to-many via WorkflowTag.
model Tag {
  id          String   @id @default(uuid())
  workspaceId String?
  name        String
  createdAt   DateTime @default(now())

  workspace Workspace?    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  workflows WorkflowTag[]

  @@index([workspaceId])
}

model WorkflowTag {
  workflowId String
  tagId      String

  workflow Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  tag      Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([workflowId, tagId])
  @@index([tagId])
}

/// A lightweight built-in key-value/tabular store, scoped to a workspace —
/// Make's "Data Store" / n8n's newer "Data Tables" equivalent, so a
/// workflow can persist simple state without an external DB credential.
/// `columns` is a loose JSON schema (array of {name, type}) the API
/// validates rows against; rows themselves are free-form JSONB.
model DataTable {
  id          String   @id @default(uuid())
  workspaceId String
  name        String
  columns     Json     @default("[]")
  createdBy   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  rows      DataTableRow[]

  @@unique([workspaceId, name])
  @@index([workspaceId])
}

model DataTableRow {
  id          String   @id @default(uuid())
  dataTableId String
  data        Json     @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  dataTable DataTable @relation(fields: [dataTableId], references: [id], onDelete: Cascade)

  @@index([dataTableId])
}

enum WorkspaceRole {
  owner
  admin
  editor
  viewer
}

enum AlertChannel {
  email
  webhook
}

/// Groups workflows, folders, and members together. Every user gets a
/// personal workspace on signup.
model Workspace {
  id        String   @id @default(uuid())
  name      String
  ownerId   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  owner     User               @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  members   WorkspaceMember[]
  folders   WorkflowFolder[]
  workflows Workflow[]
  activityLogs ActivityLog[]
  variables Variable[]
  tags      Tag[]
  dataTables DataTable[]
  logStreamConfigs LogStreamConfig[]
  subscription Subscription?
  usageCounters UsageCounter[]

  @@index([ownerId])
}

/// One billing subscription per workspace — the platform-level plan
/// (free/pro/business), as opposed to the `stripe` workflow node which lets
/// a workflow call the Stripe API as an integration action.
model Subscription {
  id                   String   @id @default(uuid())
  workspaceId          String   @unique
  plan                 String   @default("free")
  status               String   @default("active")
  stripeCustomerId     String?
  stripeSubscriptionId String?  @unique
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean  @default(false)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([stripeCustomerId])
}

/// Per-workspace, per-calendar-month execution counter used to enforce plan
/// limits and to render the usage bar in BillingPage.tsx.
model UsageCounter {
  id             String   @id @default(uuid())
  workspaceId    String
  period         String
  executionCount Int      @default(0)
  updatedAt      DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, period])
}

model WorkspaceMember {
  id          String        @id @default(uuid())
  workspaceId String
  userId      String
  role        WorkspaceRole @default(viewer)
  createdAt   DateTime      @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([userId])
}

/// Nested folders inside a workspace for organizing workflows.
model WorkflowFolder {
  id          String   @id @default(uuid())
  workspaceId String
  parentId    String?
  name        String
  createdAt   DateTime @default(now())

  workspace Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  parent    WorkflowFolder?  @relation("FolderChildren", fields: [parentId], references: [id], onDelete: SetNull)
  children  WorkflowFolder[] @relation("FolderChildren")
  workflows Workflow[]

  @@index([workspaceId])
}

/// Comments on a workflow, optionally pinned to a specific node.
model WorkflowComment {
  id         String    @id @default(uuid())
  workflowId String
  userId     String
  nodeId     String?
  body       String
  resolvedAt DateTime?
  createdAt  DateTime  @default(now())

  workflow Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([workflowId])
}

/// Append-only activity feed; workspaceId and/or workflowId may be set
/// depending on the scope of the event.
model ActivityLog {
  id          String   @id @default(uuid())
  workspaceId String?
  workflowId  String?
  userId      String?
  action      String
  metadata    Json?
  createdAt   DateTime @default(now())

  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  workflow  Workflow?  @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  user      User?      @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([workflowId])
  @@index([createdAt])
}

/// Notification config: who to notify (email or webhook) when a workflow
/// execution finishes, on failure by default.
model AlertConfig {
  id         String       @id @default(uuid())
  workflowId String
  channel    AlertChannel
  target     String
  onFailure  Boolean      @default(true)
  onSuccess  Boolean      @default(false)
  isActive   Boolean      @default(true)
  createdBy  String
  createdAt  DateTime     @default(now())

  workflow Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@index([workflowId])
}

/// Org-owner-level operational log streaming: forwards workflow execution
/// events (started/completed/failed) across the whole workspace to an
/// external endpoint (Datadog, Sentry, Slack, a custom collector, ...).
/// Distinct from AlertConfig, which is per-workflow and finish-only.
model LogStreamConfig {
  id          String   @id @default(uuid())
  workspaceId String
  name        String
  targetUrl   String
  eventTypes  Json     @default("[\"started\", \"completed\", \"failed\"]")
  isActive    Boolean  @default(true)
  headers     Json?
  createdBy   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
}

/// One immutable snapshot per save/publish, enabling rollback and diffing.
model WorkflowVersion {
  id          String   @id @default(uuid())
  workflowId  String
  version     Int
  status      WorkflowVersionStatus @default(draft)
  nodesJson   Json
  edgesJson   Json
  message     String?
  createdBy   String
  createdAt   DateTime @default(now())

  workflow    Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@unique([workflowId, version])
  @@index([workflowId])
}

enum WorkflowVersionStatus {
  draft
  published
}

/// Tracks community/marketplace node packages installed on this instance.
model CommunityNode {
  id          String   @id @default(uuid())
  name        String   @unique
  version     String
  description String
  author      String?
  homepage    String?
  nodeTypes   Json
  source      String   // 'registry' | 'npm' | 'local'
  installedBy String
  installedAt DateTime @default(now())
}

enum CredentialAuthType {
  apiKey
  oauth2
}

enum SharePermission {
  use
  manage
}

model CredentialFolder {
  id          String       @id @default(uuid())
  userId      String
  name        String
  createdAt   DateTime     @default(now())

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  credentials Credential[]

  @@index([userId])
}

model Credential {
  id              String             @id @default(uuid())
  userId          String
  name            String             @default("Untitled credential")
  type            String
  authType        CredentialAuthType @default(apiKey)
  encryptedData   String
  folderId        String?
  oauthProvider   String?
  oauthExpiresAt  DateTime?
  lastTestedAt    DateTime?
  lastTestOk      Boolean?
  lastTestMessage String?
  createdAt       DateTime           @default(now())

  user   User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  folder CredentialFolder? @relation(fields: [folderId], references: [id], onDelete: SetNull)
  shares CredentialShare[]

  @@index([userId])
  @@index([folderId])
}

model CredentialShare {
  id               String          @id @default(uuid())
  credentialId     String
  sharedWithUserId String
  permission       SharePermission @default(use)
  createdAt        DateTime        @default(now())

  credential     Credential @relation(fields: [credentialId], references: [id], onDelete: Cascade)
  sharedWithUser User       @relation(fields: [sharedWithUserId], references: [id], onDelete: Cascade)

  @@unique([credentialId, sharedWithUserId])
  @@index([sharedWithUserId])
}

/// Direct, per-user workflow share — independent of workspace membership.
/// Role uses the same rank as WorkspaceRole ('viewer' < 'editor' < 'admin');
/// the real owner is still Workflow.userId — transferring ownership updates
/// that column directly (see transferWorkflowOwnership) rather than granting
/// an 'owner' row here.
model WorkflowShare {
  id               String   @id @default(uuid())
  workflowId       String
  sharedWithUserId String
  role             String   @default("viewer")
  createdAt        DateTime @default(now())

  workflow       Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  sharedWithUser User     @relation(fields: [sharedWithUserId], references: [id], onDelete: Cascade)

  @@unique([workflowId, sharedWithUserId])
  @@index([sharedWithUserId])
  @@index([workflowId])
}

enum ExecutionStatus {
  running
  success
  failed
  paused
  cancelled
}

enum TriggerType {
  manual
  webhook
  schedule
}

model Execution {
  id          String          @id @default(uuid())
  workflowId  String
  status      ExecutionStatus @default(running)
  startedAt   DateTime        @default(now())
  finishedAt  DateTime?
  pausedAt    DateTime?
  triggerType TriggerType
  checkpoint   Json?
  resumeToken  String?         @unique
  resumeNodeId String?

  workflow Workflow            @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  nodeRuns ExecutionNodeRun[]

  @@index([workflowId])
  @@index([status])
}

enum NodeRunStatus {
  pending
  running
  success
  failed
  skipped
}

model ExecutionNodeRun {
  id          String        @id @default(uuid())
  executionId String
  nodeId      String
  status      NodeRunStatus @default(pending)
  input       Json?
  output      Json?
  error       String?
  startedAt   DateTime?
  finishedAt  DateTime?

  execution Execution @relation(fields: [executionId], references: [id], onDelete: Cascade)

  @@index([executionId])
  @@index([nodeId])
}

/// A saved sample-input/expected-output pair for a workflow, used by the
/// "Run tests" action (WorkflowTestsPage.tsx). `scorer` picks how the
/// actual run output is compared against `expectedOutput`:
///   - "jsonDiff":  deep-equal structural comparison (default)
///   - "exactString": stringified output must equal expectedOutput exactly
///   - "contains":  stringified output must contain expectedOutput as a substring
///   - "similarity": token-overlap similarity score against expectedOutput,
///                   must meet `passThreshold` (0-1, default 0.7) — the
///                   lightweight "AI evaluation mode" scorer for agent/
///                   RAG/openai nodes whose output isn't byte-exact.
model WorkflowTestCase {
  id             String   @id @default(uuid())
  workflowId     String
  name           String
  input          Json     @default("{}")
  expectedOutput Json     @default("{}")
  scorer         String   @default("jsonDiff")
  passThreshold  Float    @default(0.7)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  workflow Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@index([workflowId])
}
