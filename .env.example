# Postgres
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/flowforge?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# Auth
JWT_ACCESS_SECRET="change-me-access-secret"
JWT_REFRESH_SECRET="change-me-refresh-secret"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Credential encryption (32-byte key, base64)
CREDENTIAL_ENCRYPTION_KEY="base64-encoded-32-byte-key-here"

# API
PORT=4000
WEB_ORIGIN="http://localhost:5173"
# Publicly reachable base URL of this API (used to build OAuth redirect URIs).
# Must exactly match a redirect URI registered with each OAuth provider below.
API_PUBLIC_URL="http://localhost:4000"

# OAuth2 "Connect with ..." credentials
# Google: https://console.cloud.google.com/apis/credentials
#   Redirect URI: {API_PUBLIC_URL}/credentials/oauth/google/callback
GOOGLE_OAUTH_CLIENT_ID=""
GOOGLE_OAUTH_CLIENT_SECRET=""
# Slack: https://api.slack.com/apps -> OAuth & Permissions
#   Redirect URI: {API_PUBLIC_URL}/credentials/oauth/slack/callback
SLACK_OAUTH_CLIENT_ID=""
SLACK_OAUTH_CLIENT_SECRET=""
# GitHub: https://github.com/settings/developers
#   Redirect URI: {API_PUBLIC_URL}/credentials/oauth/github/callback
GITHUB_OAUTH_CLIENT_ID=""
GITHUB_OAUTH_CLIENT_SECRET=""

# Worker
WORKER_CONCURRENCY=5

# OpenAI (optional server-wide fallback — nodes/AI-agent can also use a
# per-user "openai" credential saved in the Credentials page instead)
OPENAI_API_KEY=""

# RAG vector store — which backend the ragIngest/ragQuery nodes use by
# default (a node can override this per-call with the "vectorStore" param).
# One of: json | pgvector | pinecone | qdrant | weaviate
RAG_VECTOR_STORE="json"

# json backend (zero extra infra, dev/small-scale only)
RAG_STORE_DIR="/tmp/flowforge-rag"

# pgvector backend — requires the `vector` extension available on the
# target Postgres (the store creates it + its table on first use).
# Falls back to DATABASE_URL if unset.
RAG_PGVECTOR_URL=""
RAG_PGVECTOR_DIM="1536"

# Pinecone backend — host is the per-index URL shown in the Pinecone console.
PINECONE_API_KEY=""
PINECONE_HOST=""

# Qdrant backend
QDRANT_URL="http://localhost:6333"
QDRANT_API_KEY=""
RAG_QDRANT_DIM="1536"

# Weaviate backend
WEAVIATE_URL="http://localhost:8080"
WEAVIATE_API_KEY=""

# Reranking (ragQuery node, rerank.provider = "cohere") — falls back to an
# LLM-based reranker using the node's "openai" credential if unset.
COHERE_API_KEY=""

# Browser automation companion service (Selenium/Playwright HTTP runner)
# See docs/browser-automation.md — only needed if you use the
# "browserAutomation" node.
BROWSER_RUNNER_URL="http://localhost:7900"
BROWSER_RUNNER_API_KEY=""

# --- Step 6: alerting/notifications (optional) ---
# Configure one to enable outbound email alerts on workflow execution failure/success.
# Without either set, alerts are still recorded in the in-app Activity Log.
RESEND_API_KEY=
SENDGRID_API_KEY=
ALERTS_FROM_EMAIL=alerts@flowforge.dev
